# ===== aiteacherguard .gitignore =====
# 무거운 학습 산출물·대용량 데이터는 git 제외 (코드/노트북 골격만 동기화)

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# --- 모델 / 가중치 / 대용량 산출물 (절대 커밋 금지) ---
*.bin
*.safetensors
*.gguf
*.pt
*.pth
*.onnx
*.ckpt
*.npz
ml/outputs/
ml/checkpoints/
ml/runs/
models/

# --- 데이터 ---
# AI Hub 데이터(data/aihub/)는 git 추적한다 — Claude가 직접 읽고 변환 스크립트를 맞춘다.
# (AI Hub 공개 데이터 + private 레포 전제. zip 같은 압축 원본만 제외하고 풀린 파일은 추적)
data/raw/
data/processed/
data/*.xlsx
data/*.parquet
*.zip
*.tar
*.tar.gz
# 더미·골든셋 등 작은 샘플은 추적 허용
!data/samples/
!data/samples/**

# --- Node / Frontend ---
node_modules/
dist/
.vite/
*.local
.env
.env.*
!.env.example

# --- OS / IDE ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# --- 비밀/자격증명 ---
*.pem
*.key
secrets.*
